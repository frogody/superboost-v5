{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "defaultMode": "auto"
  },
  "model": "fable[1m]",
  "availableModels": ["fable", "opus", "sonnet"],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent|TeamCreate|Task|Workflow",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/resource-guard.sh"
          }
        ]
      },
      {
        "matcher": "Bash|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/safety-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/ram-monitor.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/superboost-fx.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/superboost-banner.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/superboost-secrets.sh check"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/gitnexus-refresh.sh",
            "timeout": 60
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/hooks/superboost-statusline.sh"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "learning-output-style@claude-plugins-official": false,
    "superpowers@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "huggingface-skills@claude-plugins-official": true,
    "ralph-wiggum@claude-code-plugins": true,
    "playwright@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "vercel@claude-plugins-official": true,
    "codex@openai-codex": true,
    "accessibility-compliance@claude-code-workflows": true,
    "backend-api-security@claude-code-workflows": true,
    "code-refactoring@claude-code-workflows": true,
    "codebase-cleanup@claude-code-workflows": true,
    "code-documentation@claude-code-workflows": true,
    "comprehensive-review@claude-code-workflows": true,
    "warp@claude-code-warp": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "git",
        "url": "https://github.com/openai/codex-plugin-cc.git"
      }
    },
    "claude-code-workflows": {
      "source": {
        "source": "git",
        "url": "https://github.com/wshobson/agents.git"
      },
      "autoUpdate": false
    },
    "claude-code-warp": {
      "source": {
        "source": "github",
        "repo": "warpdotdev/claude-code-warp"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "skipWorkflowUsageWarning": true,
  "theme": "dark",
  "teammateMode": "in-process",
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true
}
